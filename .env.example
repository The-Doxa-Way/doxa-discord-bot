# Discord bot credentials. Get these at https://discord.com/developers/applications.
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# Optional. Set to a test guild ID for instant command registration during development.
# Leave unset for global commands (production, but 1-hour TTL).
DISCORD_GUILD_ID=

# Optional. Pass an Anthropic key for BYOL mode (unlimited calls, 1500-token cap).
# Without this, the bot uses Doxa MCP's free anon tier (50 calls/day per source IP).
# Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=
